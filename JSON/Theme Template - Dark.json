          {
            "top": 0
          },
          {
            "left": 0
          },
          {
            "right": 0
          }
        ],
        "shape": [
          {
            "$id": "default",
            "roundEdge": 8,
            "tileShape": "rectangleRounded"
          }
        ],
        "text": [
          {
            "$id": "default",
            "bold": true,
            "bottomMargin": 2,
            "fontFamily": "_font",
            "fontSize": 10,
            "horizontalAlignment": "center",
            "leftMargin": 2,
            "rightMargin": 2,
            "show": true,
            "topMargin": 2,
            "verticalAlignment": "middle"
          }
        ]
      }
    },
    "advancedSlicerVisual": {
      "*": {
        "background": [
          {
            "show": false
          }
        ],
        "border": [
          {
            "show": false
          }
        ],
        "fillCustom": [
          {
            "$id": "default",
            "fillColor": {
              "solid": {
                "color": "#171717"
              }
            },
            "transparency": 70
          },
          {
            "$id": "interaction:hover",
