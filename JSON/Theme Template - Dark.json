{
  "name": "_theme_name",
  "dataColors": [
    "_Color1",
    "_Color2",
    "_Color3",
    "_Color4",
    "_Color5",
    "_Color6",
    "_Color7",
    "_Color8"
  ],
  "background": "#000000",
  "secondaryBackground": "#000000",
  "foreground": "#ededed",
  "good": "#2E86DE",
  "bad": "#E5533D",
  "neutral": "#9AA0A6",
  "maximum": "_maximum",
  "minimum": "_minimum",
  "center": "_Color1",
  "firstLevelElements": "#ededed",
  "secondLevelElements": "#9fa1a3",
  "thirdLevelElements": "#100f0e",
  "fourthLevelElements": "#525558",
  "backgroundNeutral": "#37393b",
  "tableAccent": "#4c4c4c",
  "textClasses": {
    "boldLabel": {
      "fontFace": "_font"
    },
    "callout": {
      "color": "#dadbdc",
      "fontFace": "_font",
      "fontSize": 28
    },
    "header": {
      "color": "#dadbdc",
      "fontFace": "_font",
      "fontSize": 12
    },
    "label": {
      "color": "#4c4c4c",
      "fontFace": "_font",
      "fontSize": 10
    },
    "largeLabel": {
      "fontFace": "_font",
      "fontSize": 10
    },
    "largeLightLabel": {
      "color": "#9fa1a3",
      "fontFace": "_font",
      "fontSize": 10
    },
    "largeTitle": {
      "color": "#ffffff",
      "fontFace": "_font",
      "fontSize": 12
    },
    "lightLabel": {
      "color": "#9fa1a3"
    },
    "semiboldLabel": {
      "fontFace": "_font"
    },
    "smallLabel": {
      "fontSize": 10
    },
    "smallLightLabel": {
      "color": "#9fa1a3",
      "fontFace": "_font",
      "fontSize": 10
    },
    "title": {
      "color": "#dadbdc",
      "fontFace": "_font",
      "fontSize": 10
    }
  },
  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "color": {
              "solid": {
                "color": "#171717"
              }
            },
            "transparency": 0
          }
        ],
        "border": [
          {
            "color": {
              "solid": {
                "color": "#171717"
              }
            },
            "radius": 15,
            "show": true,
            "width": 1
          }
        ],
        "categoryAxis": [
          {
            "fontFamily": "_font",
            "fontSize": 10,
            "innerPadding": 65,
            "showAxisTitle": false,
            "titleFontFamily": "_font",
            "titleFontSize": 10
          }
        ],
        "divider": [
          {
            "show": false,
            "width": 1
          }
        ],
        "dropShadow": [
          {
            "angle": 90,
            "color": {
              "solid": {
                "color": "#000000"
              }
            },
            "position": "Outer",
            "preset": "Custom",
            "shadowBlur": 10,
            "shadowDistance": 4,
            "shadowSpread": 2,
            "show": true,
            "transparency": 95
          }
        ],
        "error": [
          {
            "labelFontFamily": "_font",
            "labelFontSize": 10
          }
        ],
        "labels": [
          {
            "backgroundColor": {
              "solid": {
                "color": "#dadbdc"
              }
            },
            "backgroundTransparency": 90,
            "detailFontFamily": "_font",
            "detailFontSize": 10,
            "enableBackground": false,
            "fontFamily": "_font",
            "fontSize": 10,
            "show": true,
            "titleFontFamily": "_font",
            "titleFontSize": 10
          }
        ],
        "legend": [
          {
            "fontFamily": "_font",
            "fontSize": 10,
            "showTitle": false
          }
        ],
        "lineStyles": [
          {
            "interpolationSmooth": "monotoneX",
            "lineChartType": "smooth",
            "markerShape": "circle",
            "markerSize": 5,
            "showMarker": true,
            "strokeWidth": 3
          }
        ],
        "padding": [
          {
            "bottom": "_padding",
            "left": "_padding",
            "right": "_padding",
            "top": "_padding"
          }
        ],
        "seriesLabels": [
          {
            "seriesFontFamily": "_font",
            "textSize": 10
          }
        ],
        "spacing": [
          {
            "customizeSpacing": true,
            "spaceBelowSubTitle": 12,
            "spaceBelowTitle": 6
          }
        ],
        "subTitle": [
          {
            "fontFamily": "_font",
            "fontSize": 10
          },
          {
            "fontColor": {
              "solid": {
                "color": "#9fa1a3"
              }
            }
          }
        ],
        "title": [
          {
            "bold": true,
            "fontFamily": "_font",
            "fontSize": 12
          },
          {
            "fontColor": {
              "solid": {
                "color": "#dadbdc"
              }
            }
          }
        ],
        "totals": [
          {
            "bold": true,
            "fontFamily": "_font",
            "fontSize": 10,
            "show": true
          }
        ],
        "valueAxis": [
          {
            "fontFamily": "_font",
            "fontSize": 10,
            "gridlineShow": true,
            "gridlineStyle": "dotted",
            "gridlineThickness": 1,
            "innerPadding": 65,
            "showAxisTitle": false,
            "titleFontFamily": "_font",
            "titleFontSize": 10
          }
        ],
        "visualTooltip": [
          {
            "type": "Default",
            "foreground": {
              "solid": {
                "color": "#EAEAEA"
              }
            },
            "titleFontColor": {
              "solid": {
                "color": "#C8C8C8"
              }
            },
            "valueFontColor": {
              "solid": {
                "color": "#EAEAEA"
              }
            },
            "border": {
              "solid": {
                "color": "#141414"
              }
            },
            "background": {
              "solid": {
                "color": "#141414"
              }
            },
            "transparency": 8
          }
        ],
        "visualHeader": [
          {
            "show": false,
            "foreground": {
              "solid": {
                "color": "#9fa1a3"
              }
            },
            "border": {
              "solid": {
                "color": "#141414"
              }
            },
            "background": {
              "solid": {
                "color": "#141414"
              }
            },
            "transparency": 8
          }
        ]
      }
    },
    "actionButton": {
      "*": {
        "border": [
          {
            "show": false
          }
        ],
        "dropShadow": [
          {
            "show": false
          }
        ],
